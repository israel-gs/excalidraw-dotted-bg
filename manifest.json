{
  "manifest_version": 3,
  "name": "Excalidraw Dotted Background",
  "version": "1.1.0",
  "description": "Adds a configurable dotted background to Excalidraw.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Excalidraw Dotted Background"
  },
  "content_scripts": [
    {
      "matches": [
        "https://excalidraw.com/*",
        "https://*.excalidraw.com/*"
      ],
      "css": ["content.css"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://excalidraw.com/*",
        "https://*.excalidraw.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
